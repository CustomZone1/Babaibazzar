import Link from "next/link";
import Image from "next/image";
import { prisma } from "@/lib/prisma";

function money(paise: number) {
  return `₹${Math.round(paise / 100)}`;
}

function safeImg(src?: string | null) {
  if (!src) return null;
  const s = src.trim();
  if (!s) return null;
  if (s.startsWith("/") || s.startsWith("http://") || s.startsWith("https://")) return s;
  if (s.startsWith("uploads/")) return `/${s}`;
  return s;
}

export default async function HomePage() {
  // ✅ Open shops
  const shops = await prisma.shop.findMany({
    orderBy: [{ isOpen: "desc" }, { createdAt: "desc" }],
    take: 8,
  });

  // ✅ Trending products (across all shops)
  const trending = await prisma.product.findMany({
    where: { isActive: true, inStock: true },
    orderBy: [{ updatedAt: "desc" }],
    take: 10,
    include: { shop: true },
  });

  // ✅ Categories (Blinkit style chips)
  const rawCats = await prisma.product.findMany({
    where: { isActive: true, category: { not: null } },
    distinct: ["category"],
    select: { category: true },
    take: 14,
  });

  const categories = rawCats
    .map((c) => c.category)
    .filter(Boolean)
    .map((c) => String(c));

  return (
    <div className="mx-auto max-w-6xl px-4 py-8">
      {/* ================= HERO (Premium / Zepto vibe) ================= */}
      <div className="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-black via-neutral-950 to-neutral-900 p-8 text-white shadow-xl">
        {/* glow blobs */}
        <div className="pointer-events-none absolute -top-24 -right-24 h-72 w-72 rounded-full bg-emerald-500/20 blur-3xl" />
        <div className="pointer-events-none absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-indigo-500/20 blur-3xl" />

        <div className="relative grid gap-6 md:grid-cols-2 md:items-center">
          <div>
            <div className="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-neutral-200">
              <span className="inline-block h-2 w-2 rounded-full bg-emerald-400" />
              Delivery in minutes • Local shops
            </div>

            <h1 className="mt-4 text-4xl font-bold leading-tight md:text-5xl">
              Groceries from nearby shops,
              <span className="text-emerald-400"> delivered fast</span>.
            </h1>

            <p className="mt-3 text-base text-neutral-300">
              Search products across shops, compare prices, and order instantly.
            </p>

            <div className="mt-6 flex flex-wrap gap-3">
              <Link
                href="/search"
                className="rounded-xl bg-white px-5 py-3 text-sm font-semibold text-black hover:opacity-90"
              >
                Search products
              </Link>

              <Link
                href="/cart"
                className="rounded-xl border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
              >
                View cart
              </Link>

              <Link
                href="/admin"
                className="rounded-xl border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
              >
                Admin
              </Link>
            </div>

            <div className="mt-6 flex flex-wrap gap-2 text-xs text-neutral-300">
              <span className="rounded-full bg-white/5 px-3 py-1 border border-white/10">COD available</span>
              <span className="rounded-full bg-white/5 px-3 py-1 border border-white/10">Simple checkout</span>
              <span className="rounded-full bg-white/5 px-3 py-1 border border-white/10">One-cart per shop</span>
            </div>
          </div>

          {/* Right side: “feature tiles” */}
          <div className="grid gap-3 sm:grid-cols-2">
            <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
              <div className="text-sm font-semibold">⚡ Fast local delivery</div>
              <div className="mt-1 text-xs text-neutral-300">
                Shops near you deliver quickly.
              </div>
            </div>

            <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
              <div className="text-sm font-semibold">💸 Better pricing</div>
              <div className="mt-1 text-xs text-neutral-300">
                App price shown clearly.
              </div>
            </div>

            <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
              <div className="text-sm font-semibold">🧾 Clean checkout</div>
              <div className="mt-1 text-xs text-neutral-300">
                Add to cart, confirm order.
              </div>
            </div>

            <div className="rounded-2xl border border-white/10 bg-white/5 p-4">
              <div className="text-sm font-semibold">🏪 Multiple shops</div>
              <div className="mt-1 text-xs text-neutral-300">
                Discover nearby stores.
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* ================= Category chips ================= */}
      {categories.length > 0 ? (
        <div className="mt-8">
          <div className="mb-3 flex items-end justify-between">
            <h2 className="text-xl font-bold">Popular categories</h2>
            <Link href="/search" className="text-sm text-neutral-600 hover:underline">
              See all →
            </Link>
          </div>

          <div className="flex flex-wrap gap-2">
            {categories.map((c) => (
              <Link
                key={c}
                href={`/search?category=${encodeURIComponent(c)}`}
                className="rounded-full border bg-white px-4 py-2 text-sm font-medium text-neutral-800 hover:bg-neutral-50"
              >
                {c}
              </Link>
            ))}
          </div>
        </div>
      ) : null}

      {/* ================= Trending products ================= */}
      <div className="mt-10">
        <div className="mb-4 flex items-end justify-between">
          <h2 className="text-xl font-bold">🔥 Trending near you</h2>
          <Link href="/search" className="text-sm text-neutral-600 hover:underline">
            Search more →
          </Link>
        </div>

        <div className="grid grid-cols-2 gap-3 md:grid-cols-4 lg:grid-cols-5">
          {trending.map((p) => {
            const img = safeImg(p.imageUrl);
            return (
              <Link
                key={p.id}
                href={`/shop/${p.shopId}`}
                className="group rounded-2xl border bg-white p-3 hover:shadow-md transition"
              >
                <div className="relative mb-3 aspect-square overflow-hidden rounded-xl bg-neutral-50">
                  {img ? (
                    <Image
                      src={img}
                      alt={p.name}
                      fill
                      className="object-cover group-hover:scale-[1.03] transition"
                      sizes="200px"
                      unoptimized
                    />
                  ) : (
                    <div className="flex h-full w-full items-center justify-center text-xs text-neutral-400">
                      No image
                    </div>
                  )}
                </div>

                <div className="truncate text-sm font-semibold">{p.name}</div>
                <div className="truncate text-xs text-neutral-500">{p.shop.name}</div>

                <div className="mt-2 flex items-center justify-between">
                  <div className="font-bold text-emerald-700">{money(p.appPricePaise)}</div>
                  <div className="text-xs text-neutral-400 line-through">
                    {money(p.shopPricePaise)}
                  </div>
                </div>
              </Link>
            );
          })}
        </div>
      </div>

      {/* ================= Shops ================= */}
      <div className="mt-12">
        <div className="mb-4 flex items-end justify-between">
          <h2 className="text-xl font-bold">🏬 Shops</h2>
          <Link href="/search" className="text-sm text-neutral-600 hover:underline">
            Search products →
          </Link>
        </div>

        <div className="grid gap-4 md:grid-cols-2">
          {shops.map((s) => (
            <Link
              key={s.id}
              href={`/shop/${s.id}`}
              className="rounded-2xl border bg-white p-6 hover:shadow-lg transition"
            >
              <div className="flex items-start justify-between gap-3">
                <div className="min-w-0">
                  <div className="truncate text-lg font-semibold">{s.name}</div>
                  <div className="mt-1 truncate text-sm text-neutral-600">{s.addressLine}</div>

                  <div className="mt-3 flex flex-wrap gap-2 text-xs">
                    <span
                      className={`rounded-full px-3 py-1 border ${
                        s.isOpen
                          ? "bg-emerald-50 text-emerald-700 border-emerald-200"
                          : "bg-red-50 text-red-700 border-red-200"
                      }`}
                    >
                      {s.isOpen ? "Open now" : "Closed"}
                    </span>

                    <span className="rounded-full bg-neutral-50 px-3 py-1 border border-neutral-200 text-neutral-700">
                      Fast delivery
                    </span>
                    <span className="rounded-full bg-neutral-50 px-3 py-1 border border-neutral-200 text-neutral-700">
                      Local kirana
                    </span>
                  </div>
                </div>

                <div className="shrink-0 rounded-xl bg-black px-4 py-2 text-sm font-semibold text-white">
                  Open →
                </div>
              </div>
            </Link>
          ))}
        </div>
      </div>
    </div>
  );
}
